{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QR Menu",
  "version": "1.0.0",
  "identifier": "com.qrmenu.app",
  "build": {
    "devUrl": "http://localhost:3000/options",
    "frontendDist": "http://localhost:3000/options",
    "beforeDevCommand": "cd backend && node src/index.js & cd frontend && npm run dev",
    "beforeBuildCommand": "cd frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "QR Menu - Restaurant Ordering System",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:* ws://localhost:*; img-src 'self' http://localhost:* data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' http://localhost:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
